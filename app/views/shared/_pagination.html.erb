<% if pagy.pages > 1 %>
  <nav class="mt-4 flex items-center justify-between text-sm text-gray-600">
    <span>共 <%= number_with_delimiter(pagy.count) %> 筆,第 <%= pagy.page %> / <%= pagy.pages %> 頁</span>
    <div class="flex gap-2">
      <% if pagy.prev %>
        <%= link_to "上一頁", pagy_url_for(pagy, pagy.prev), class: "rounded-md border border-gray-300 bg-white px-3 py-1.5 hover:bg-gray-50" %>
      <% end %>
      <% if pagy.next %>
        <%= link_to "下一頁", pagy_url_for(pagy, pagy.next), class: "rounded-md border border-gray-300 bg-white px-3 py-1.5 hover:bg-gray-50" %>
      <% end %>
    </div>
  </nav>
<% end %>
