<% content_for :title, "登入 - Sendora" %>

<h1 class="text-2xl font-bold">登入</h1>

<%= form_with url: session_url, class: "contents" do |form| %>
  <div class="my-5">
    <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "#{ApplicationHelper::INPUT_CLASSES} mt-1" %>
  </div>

  <div class="my-5">
    <%= form.label :password, "密碼", class: "block text-sm font-medium text-gray-700" %>
    <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "#{ApplicationHelper::INPUT_CLASSES} mt-1" %>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit "登入", class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
    <%= link_to "忘記密碼?", new_password_path, class: "text-sm text-gray-700 underline hover:no-underline" %>
  </div>
<% end %>

<p class="mt-6 text-sm text-gray-500">
  還沒有帳號?<%= link_to "註冊", new_registration_path, class: "text-indigo-600 underline hover:no-underline" %>
</p>
