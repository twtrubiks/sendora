<%= form_with model: audience, url: url, data: { controller: "conditions" }, class: "contents" do |form| %>
  <div class="my-5 max-w-md">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, required: true, class: "#{ApplicationHelper::INPUT_CLASSES} mt-1" %>
    <%= field_error audience, :name %>
  </div>

  <div class="my-5">
    <p class="text-sm font-medium text-gray-700">條件(列與列之間為「且」,留空的列會被忽略)</p>

    <div data-conditions-target="rows" class="mt-2 space-y-2">
      <% audience_condition_rows(audience).each do |key, value| %>
        <%= render "condition_row", key: key, value: value %>
      <% end %>
    </div>

    <template data-conditions-target="template">
      <%= render "condition_row", key: "tag", value: nil %>
    </template>

    <button type="button" data-action="conditions#add"
            class="mt-3 cursor-pointer rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50">
      + 新增條件
    </button>

    <p class="mt-3 text-sm text-gray-500">沒有任何條件時,代表團隊的全部客戶。此分群會在每次使用時重新計算,不保存固定名單。</p>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= button_tag "預覽人數", type: "submit", formaction: preview_audiences_path,
                   data: { turbo_frame: "audience_preview" },
                   class: "cursor-pointer rounded-md border border-indigo-300 bg-white px-3.5 py-2.5 font-medium text-indigo-700 hover:bg-indigo-50" %>
    <%= turbo_frame_tag "audience_preview" do %>
      <span class="text-sm text-gray-500">按「預覽人數」立即計算符合的客戶數</span>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit submit_label, class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
    <%= link_to "取消", audiences_path, class: "text-sm text-gray-500 underline hover:no-underline" %>
  </div>
<% end %>
