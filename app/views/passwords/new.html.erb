<% content_for :title, "忘記密碼 - Sendora" %>

<h1 class="text-2xl font-bold">忘記密碼?</h1>
<p class="mt-2 text-sm text-gray-500">輸入註冊時的 Email,我們會寄送重設密碼的連結給你。</p>

<%= form_with url: passwords_path, class: "contents" do |form| %>
  <div class="my-5">
    <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700" %>
    <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address], class: "#{ApplicationHelper::INPUT_CLASSES} mt-1" %>
  </div>

  <%= form.submit "寄送重設連結", class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
<% end %>

<p class="mt-6 text-sm text-gray-500">
  <%= link_to "回登入頁", new_session_path, class: "text-indigo-600 underline hover:no-underline" %>
</p>
