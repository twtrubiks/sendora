<% content_for :title, "退訂 - Sendora" %>

<div class="rounded-lg border border-gray-200 bg-white p-6 text-center">
  <h1 class="text-xl font-bold">退訂行銷信件</h1>
  <p class="mt-3 text-sm text-gray-600">
    確認後,<span class="font-medium"><%= @customer.email %></span> 將不再收到此寄件者的行銷信件。
  </p>

  <%= button_to "確認退訂", unsubscribe_path(params[:token]), method: :post,
                class: "mt-6 cursor-pointer rounded-md bg-indigo-600 px-5 py-2.5 font-medium text-white hover:bg-indigo-500" %>
</div>
