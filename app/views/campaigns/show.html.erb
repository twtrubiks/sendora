<% content_for :title, "#{@campaign.name} - Sendora" %>

<p class="mb-4">
  <%= link_to "← 回活動列表", campaigns_path, class: "text-sm text-gray-500 underline hover:no-underline" %>
</p>

<div class="flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold"><%= @campaign.name %></h1>
    <p class="mt-1 text-sm text-gray-500">
      主旨:<%= @campaign.subject %> · 分群:<%= @campaign.audience.name %>
      <% if @campaign.sent_at %> · 發送於 <%= @campaign.sent_at.strftime("%Y-%m-%d %H:%M") %><% end %>
    </p>
  </div>
  <%= button_to "複製", duplicate_campaign_path(@campaign), method: :post,
                class: "cursor-pointer rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
</div>

<%= turbo_frame_tag @campaign, src: campaign_path(@campaign), target: "_top" do %>
  <div <% if @campaign.sending? %>data-controller="poll"<% end %> class="mt-6 max-w-4xl">
    <div class="flex items-center gap-3">
      <%= render "campaigns/status_badge", campaign: @campaign %>
      <% if @campaign.sending? %>
        <span class="text-sm text-gray-500">發送中,本頁會自動更新…</span>
      <% end %>
    </div>

    <% if @campaign.failed? %>
      <div class="mt-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700"><%= @campaign.error_message %></div>
    <% end %>

    <div class="mt-4 grid max-w-xl grid-cols-3 gap-4">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <p class="text-xs text-gray-500">寄達</p>
        <p class="mt-1 text-xl font-semibold text-green-600"><%= number_with_delimiter(@sent_count) %></p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <p class="text-xs text-gray-500">失敗</p>
        <p class="mt-1 text-xl font-semibold <%= @failed_count.positive? ? 'text-red-600' : '' %>"><%= number_with_delimiter(@failed_count) %></p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <p class="text-xs text-gray-500">待寄送</p>
        <p class="mt-1 text-xl font-semibold"><%= number_with_delimiter(@pending_count) %></p>
      </div>
    </div>

    <% unless @campaign.sending? %>
      <div class="mt-4">
        <%= link_to "下載成效 CSV", campaign_path(@campaign, format: :csv), class: "text-sm text-indigo-600 underline hover:no-underline", data: { turbo: false } %>
      </div>
    <% end %>

    <% if @failed_deliveries.any? %>
      <section class="mt-6">
        <h2 class="font-semibold text-gray-900">失敗清單</h2>
        <div class="mt-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 text-xs text-gray-500">
              <tr>
                <th class="px-4 py-2 font-medium">Email</th>
                <th class="px-4 py-2 font-medium">原因</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% @failed_deliveries.each do |delivery| %>
                <tr>
                  <td class="px-4 py-2 text-gray-900"><%= delivery.customer.email %></td>
                  <td class="px-4 py-2 text-gray-600"><%= delivery.error_message %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <%= render "shared/pagination", pagy: @pagy %>
      </section>
    <% end %>
  </div>
<% end %>
