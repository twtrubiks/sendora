<% content_for :title, "編輯活動 - Sendora" %>

<div class="flex items-center justify-between">
  <h1 class="text-2xl font-bold">編輯活動(草稿)</h1>
  <%= button_to "刪除草稿", campaign_path(@campaign), method: :delete,
                data: { turbo_confirm: "確定要刪除草稿「#{@campaign.name}」?" },
                class: "cursor-pointer text-sm text-red-600 hover:underline" %>
</div>

<div class="mt-4 max-w-3xl rounded-lg border border-gray-200 bg-white p-5">
  <%= render "form", campaign: @campaign, url: campaign_path(@campaign) %>
</div>
