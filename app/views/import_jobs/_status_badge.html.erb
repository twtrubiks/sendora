<% classes = {
     "pending" => "bg-yellow-100 text-yellow-800",
     "processing" => "bg-yellow-100 text-yellow-800",
     "completed" => import_job.failure_count.positive? ? "bg-orange-100 text-orange-800" : "bg-green-100 text-green-700",
     "failed" => "bg-red-100 text-red-700"
   }.fetch(import_job.status) %>
<span class="rounded-full px-2 py-0.5 text-xs font-medium <%= classes %>">
  <%= import_job.completed? && import_job.failure_count.positive? ? "部分失敗" : t("import_jobs.statuses.#{import_job.status}") %>
</span>
