<% content_for :title, "匯入 - #{Current.team.name} - Sendora" %>

<h1 class="text-2xl font-bold">匯入</h1>
<p class="mt-1 text-sm text-gray-500">上傳 CSV 檔批次匯入客戶與訂單,成功的列直接寫入,失敗的列會留下原因。</p>

<div class="mt-6 grid max-w-4xl gap-6 lg:grid-cols-2">
  <section class="rounded-lg border border-gray-200 bg-white p-5">
    <h2 class="font-semibold text-gray-900">上傳 CSV</h2>

    <%= form_with model: @import_job, url: import_jobs_path, class: "contents" do |form| %>
      <div class="my-4">
        <%= form.label :kind, "匯入類型", class: "block text-sm font-medium text-gray-700" %>
        <%= form.select :kind, [ [ "客戶資料", "customers" ], [ "訂單資料", "orders" ] ], {}, class: "#{ApplicationHelper::INPUT_CLASSES} mt-1" %>
      </div>

      <div class="my-4">
        <%= form.label :file, "CSV 檔案", class: "block text-sm font-medium text-gray-700" %>
        <%= form.file_field :file, accept: ".csv,text/csv", required: true,
              class: "mt-1 block w-full text-sm text-gray-700 file:mr-3 file:cursor-pointer file:rounded-md file:border-0 file:bg-indigo-50 file:px-3 file:py-2 file:font-medium file:text-indigo-700 hover:file:bg-indigo-100" %>
        <p class="mt-1 text-sm text-gray-500">限 CSV 格式,10MB 以內,需含標題列。</p>
        <%= field_error @import_job, :file %>
      </div>

      <%= form.submit "上傳並開始匯入", class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
    <% end %>
  </section>

  <section class="rounded-lg border border-gray-200 bg-white p-5 text-sm">
    <h2 class="font-semibold text-gray-900">檔案格式</h2>

    <div class="mt-3">
      <p class="font-medium text-gray-700">客戶資料 <%= link_to "下載範本", template_import_jobs_path(kind: "customers"), class: "ml-2 text-indigo-600 underline hover:no-underline", data: { turbo: false } %></p>
      <p class="mt-1 text-gray-500">欄位:<code class="rounded bg-gray-100 px-1">email</code>(必填)、<code class="rounded bg-gray-100 px-1">name</code>、<code class="rounded bg-gray-100 px-1">phone</code>。email 重複時以檔案中較後的列為準。</p>
    </div>

    <div class="mt-4">
      <p class="font-medium text-gray-700">訂單資料 <%= link_to "下載範本", template_import_jobs_path(kind: "orders"), class: "ml-2 text-indigo-600 underline hover:no-underline", data: { turbo: false } %></p>
      <p class="mt-1 text-gray-500">欄位:<code class="rounded bg-gray-100 px-1">email</code>、<code class="rounded bg-gray-100 px-1">number</code>、<code class="rounded bg-gray-100 px-1">amount</code>、<code class="rounded bg-gray-100 px-1">ordered_at</code>(皆必填)。email 必須是已存在的客戶,請先匯入客戶。</p>
    </div>
  </section>
</div>

<section class="mt-8 max-w-4xl">
  <h2 class="font-semibold text-gray-900">匯入紀錄</h2>

  <div class="mt-3 overflow-hidden rounded-lg border border-gray-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-gray-50 text-xs text-gray-500">
        <tr>
          <th class="px-4 py-2 font-medium">檔名</th>
          <th class="px-4 py-2 font-medium">類型</th>
          <th class="px-4 py-2 font-medium">狀態</th>
          <th class="px-4 py-2 font-medium">成功 / 失敗</th>
          <th class="px-4 py-2 font-medium">上傳時間</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @import_jobs.each do |job| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2"><%= link_to job.filename, import_job_path(job), class: "font-medium text-indigo-600 hover:underline" %></td>
            <td class="px-4 py-2 text-gray-700"><%= t("import_jobs.kinds.#{job.kind}") %></td>
            <td class="px-4 py-2"><%= render "import_jobs/status_badge", import_job: job %></td>
            <td class="px-4 py-2 text-gray-700">
              <% if job.in_progress? %>—<% else %><%= number_with_delimiter(job.success_count) %> / <%= number_with_delimiter(job.failure_count) %><% end %>
            </td>
            <td class="px-4 py-2 text-gray-500"><%= job.created_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        <% end %>
        <% if @import_jobs.empty? %>
          <tr><td colspan="5" class="px-4 py-6 text-center text-gray-500">還沒有匯入紀錄</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= render "shared/pagination", pagy: @pagy %>
</section>
