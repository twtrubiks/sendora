<% content_for :title, "成員 - #{Current.team.name} - Sendora" %>

<%= render "settings/nav" %>

<div class="mt-6 max-w-2xl space-y-6">
  <section class="rounded-lg border border-gray-200 bg-white p-5">
    <h2 class="font-semibold text-gray-900">邀請成員</h2>
    <p class="mt-1 text-sm text-gray-500">輸入對方註冊 Sendora 時使用的 Email;尚未註冊的人請先請對方完成註冊。</p>

    <%= form_with url: settings_memberships_path, method: :post, class: "mt-4 flex items-center gap-3" do |form| %>
      <%= form.email_field :email_address, required: true, placeholder: "member@example.com", class: ApplicationHelper::INPUT_CLASSES %>
      <%= form.submit "邀請", class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-lg border border-gray-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-gray-50 text-xs text-gray-500">
        <tr>
          <th class="px-4 py-2 font-medium">Email</th>
          <th class="px-4 py-2 font-medium">角色</th>
          <th class="px-4 py-2 font-medium">加入時間</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @memberships.each do |membership| %>
          <tr>
            <td class="px-4 py-2.5 text-gray-900"><%= membership.user.email_address %></td>
            <td class="px-4 py-2.5">
              <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700"><%= t("roles.#{membership.role}") %></span>
            </td>
            <td class="px-4 py-2.5 text-gray-500"><%= membership.created_at.strftime("%Y-%m-%d") %></td>
            <td class="px-4 py-2.5 text-right">
              <%= button_to "移除", settings_membership_path(membership), method: :delete,
                            data: { turbo_confirm: "確定要將 #{membership.user.email_address} 移出團隊?" },
                            class: "cursor-pointer text-sm text-red-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
