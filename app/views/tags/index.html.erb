<% content_for :title, "標籤管理 - #{Current.team.name} - Sendora" %>

<div class="flex items-center justify-between">
  <h1 class="text-2xl font-bold">標籤管理</h1>
  <%= link_to "← 回客戶列表", customers_path, class: "text-sm text-gray-500 underline hover:no-underline" %>
</div>

<div class="mt-6 max-w-2xl space-y-6">
  <section class="rounded-lg border border-gray-200 bg-white p-5">
    <h2 class="font-semibold text-gray-900">建立標籤</h2>
    <%= form_with model: @tag, url: tags_path, class: "mt-3 flex items-center gap-3" do |form| %>
      <%= form.text_field :name, required: true, placeholder: "例如:VIP", class: "#{ApplicationHelper::INPUT_CLASSES} max-w-xs" %>
      <%= form.submit "建立", class: ApplicationHelper::PRIMARY_BUTTON_CLASSES %>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-lg border border-gray-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-gray-50 text-xs text-gray-500">
        <tr>
          <th class="px-4 py-2 font-medium">標籤</th>
          <th class="px-4 py-2 font-medium">客戶數</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tags.each do |tag| %>
          <tr>
            <td class="px-4 py-2">
              <span class="rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700"><%= tag.name %></span>
            </td>
            <td class="px-4 py-2 text-gray-700"><%= number_with_delimiter(tag.customers_count) %></td>
            <td class="px-4 py-2 text-right">
              <%= link_to "改名", edit_tag_path(tag), class: "mr-3 text-sm text-indigo-600 hover:underline" %>
              <%= button_to "刪除", tag_path(tag), method: :delete,
                            data: { turbo_confirm: "確定要刪除標籤「#{tag.name}」?已貼此標籤的客戶會自動撕下。" },
                            class: "inline cursor-pointer text-sm text-red-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
        <% if @tags.empty? %>
          <tr><td colspan="3" class="px-4 py-6 text-center text-gray-500">還沒有標籤,先建立一個吧</td></tr>
        <% end %>
      </tbody>
    </table>
  </section>
</div>
